# ============================================================
# Personal Automation System — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ---- REQUIRED ----

# Telegram Bot API token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Anthropic Claude API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Management GUI authentication token (choose a strong random string)
GUI_AUTH_TOKEN=

# ---- OLLAMA (optional) ----

# Ollama server URL. Leave empty to use Claude for ALL LLM tasks (no local model).
# OLLAMA_URL=http://ollama:11434
OLLAMA_URL=

# Default local model for classification and parsing (only used when OLLAMA_URL is set)
OLLAMA_MODEL=llama3.2:3b

# ---- CLAUDE ----

# Default Claude model for complex reasoning
CLAUDE_MODEL=claude-sonnet-4-20250514

# Fast Claude model for classification/extraction (used when Ollama is unavailable)
# Leave empty to default to claude-haiku-4-5-20251001
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# ---- ADDITIONAL LLM PROVIDERS (optional) ----

# Google AI API key (get from aistudio.google.com)
# Enables Gemini models for fast/standard tiers
# GOOGLE_AI_API_KEY=

# OpenAI API key (get from platform.openai.com)
# Enables GPT models for fast/standard tiers
# OPENAI_API_KEY=

# For additional providers (Groq, Together, Mistral, etc.),
# add OpenAI-compatible endpoints in config/pas.yaml under llm.providers.

# ---- EXTERNAL API (optional) ----

# Bearer token for external data API (e.g., n8n integration)
# Leave empty to disable the API endpoints entirely.
# API_TOKEN=
API_TOKEN=

# ---- SERVER ----

# Port for Fastify server (webhook + GUI)
PORT=3000

# Node environment
NODE_ENV=production

# Set to true when behind a reverse proxy (Cloudflare Tunnel, nginx, etc.)
# Ensures request.ip reflects the real client IP for rate limiting
# TRUST_PROXY=true

# ---- WEBHOOK ----

# Telegram webhook URL (optional — set to auto-register webhook on startup)
# Must be the full HTTPS URL, e.g. https://your-domain.com/webhook/telegram
# WEBHOOK_URL=

# Webhook secret token for request authentication (optional)
# If not set, a secret is auto-derived from TELEGRAM_BOT_TOKEN.
# Validated via X-Telegram-Bot-Api-Secret-Token header.
# TELEGRAM_WEBHOOK_SECRET=

# ---- CLOUDFLARE TUNNEL ----

# Cloudflare Tunnel token (get from Cloudflare Zero Trust dashboard)
CLOUDFLARE_TUNNEL_TOKEN=

# ---- OPTIONAL: Google Calendar ----

# Google Calendar API credentials (needed for calendar-dependent features)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=

# ---- OPTIONAL: Weather ----

# OpenWeatherMap API key (needed for weather-dependent features)
# OPENWEATHERMAP_API_KEY=

# ---- OPTIONAL: Audio ----

# Default Chromecast device name for audio casting
# CHROMECAST_DEVICE=Living Room speaker

# ---- DATA ----

# Path to data directory (default: ./data)
DATA_DIR=./data

# ---- LOGGING ----

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
