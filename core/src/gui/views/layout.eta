<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= it.title || 'PAS Management' %></title>
  <link rel="stylesheet" href="/gui/public/pico.min.css" />
  <link rel="stylesheet" href="/gui/public/pas.css" />
  <script src="/gui/public/htmx.min.js"></script>
  <% if (it.csrfToken) { %>
  <meta name="csrf-token" content="<%= it.csrfToken %>" />
  <% } %>
  <script>
    document.addEventListener('htmx:configRequest', function(event) {
      var meta = document.querySelector('meta[name="csrf-token"]');
      if (meta) { event.detail.headers['X-CSRF-Token'] = meta.getAttribute('content'); }
    });
  </script>
</head>
<body>
  <!-- Top bar -->
  <header class="pas-topbar">
    <div class="pas-topbar-left">
      <button class="pas-hamburger" id="sidebar-toggle" type="button" title="Toggle navigation" aria-label="Toggle navigation">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <a href="/gui/" class="pas-brand">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        PAS
      </a>
      <a href="/gui/" class="pas-topbar-link <% if (it.activePage === 'dashboard') { %>active<% } %>" title="Dashboard">
        Dashboard
      </a>
    </div>
    <div class="pas-topbar-right">
      <button class="theme-toggle" id="theme-toggle" title="Toggle dark mode" type="button">&#9790;</button>
      <form method="post" action="/gui/logout" style="margin:0">
        <% if (it.csrfToken) { %><input type="hidden" name="_csrf" value="<%= it.csrfToken %>" /><% } %>
        <button type="submit" class="outline secondary" style="padding:0.25rem 0.5rem;margin:0;border-radius:999px;font-size:0.85rem">Logout</button>
      </form>
    </div>
  </header>

  <!-- App layout: sidebar + content -->
  <div class="pas-app-layout">
    <!-- Left sidebar -->
    <aside class="pas-sidebar" id="pas-sidebar">
      <nav>
        <ul>
          <li>
            <a href="/gui/apps" title="Apps" <% if (it.activePage === 'apps') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              <span class="nav-label">Apps</span>
            </a>
          </li>
          <li>
            <a href="/gui/scheduler" title="Scheduler" <% if (it.activePage === 'scheduler') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span class="nav-label">Scheduler</span>
            </a>
          </li>
          <li class="nav-section-divider"></li>
          <li>
            <a href="/gui/reports" title="Reports" <% if (it.activePage === 'reports') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              <span class="nav-label">Reports</span>
            </a>
          </li>
          <li>
            <a href="/gui/alerts" title="Alerts" <% if (it.activePage === 'alerts') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              <span class="nav-label">Alerts</span>
            </a>
          </li>
          <li class="nav-section-divider"></li>
          <li>
            <a href="/gui/spaces" title="Spaces" <% if (it.activePage === 'spaces') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span class="nav-label">Spaces</span>
            </a>
          </li>
          <li>
            <a href="/gui/users" title="Users" <% if (it.activePage === 'users') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span class="nav-label">Users</span>
            </a>
          </li>
          <li>
            <a href="/gui/context" title="Context" <% if (it.activePage === 'context') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              <span class="nav-label">Context</span>
            </a>
          </li>
          <li>
            <a href="/gui/data" title="Data" <% if (it.activePage === 'data') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              <span class="nav-label">Data</span>
            </a>
          </li>
          <li class="nav-section-divider"></li>
          <li>
            <a href="/gui/logs" title="Logs" <% if (it.activePage === 'logs') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
              <span class="nav-label">Logs</span>
            </a>
          </li>
          <li>
            <a href="/gui/llm" title="LLM" <% if (it.activePage === 'llm') { %>aria-current="page"<% } %>>
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/><circle cx="12" cy="15" r="2"/></svg>
              <span class="nav-label">LLM</span>
            </a>
          </li>
        </ul>
      </nav>
    </aside>

    <!-- Sidebar overlay (mobile) -->
    <div class="pas-sidebar-overlay" id="sidebar-overlay"></div>

    <!-- Main content -->
    <div class="pas-main-content">
      <main>
        <%~ it.body %>
      </main>
      <footer class="pas-footer">
        Personal Automation System
      </footer>
    </div>
  </div>

  <script>
    (function() {
      // Theme toggle
      var saved = localStorage.getItem('pas-theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
      var btn = document.getElementById('theme-toggle');
      if (btn) {
        function updateIcon() {
          btn.textContent = document.documentElement.getAttribute('data-theme') === 'dark' ? '\u2600' : '\u263E';
        }
        updateIcon();
        btn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('pas-theme', next);
          updateIcon();
        });
      }

      // Sidebar toggle
      var toggle = document.getElementById('sidebar-toggle');
      var sidebar = document.getElementById('pas-sidebar');
      var overlay = document.getElementById('sidebar-overlay');
      if (toggle && sidebar && overlay) {
        toggle.addEventListener('click', function() {
          sidebar.classList.toggle('open');
          overlay.classList.toggle('visible');
        });
        overlay.addEventListener('click', function() {
          sidebar.classList.remove('open');
          overlay.classList.remove('visible');
        });
      }

      // Restore sidebar collapsed state
      var sidebarCollapsed = localStorage.getItem('pas-sidebar-collapsed');
      if (sidebarCollapsed === 'true' && sidebar) {
        sidebar.classList.add('collapsed');
      }

      // Delegated handlers for data-pick-path (file picker) and data-confirm-delete
      document.addEventListener('click', function(e) {
        if (!e.target || !(e.target instanceof Element)) return;
        // File picker: set input value and remove browser
        var pick = e.target.closest('[data-pick-path]');
        if (pick) {
          e.preventDefault();
          var input = document.getElementsByName(pick.getAttribute('data-pick-target') || '')[0];
          if (input) input.value = pick.getAttribute('data-pick-path') || '';
          var browser = pick.closest('.file-browser-list');
          if (browser) browser.remove();
          return;
        }
        // File picker: close browser
        var close = e.target.closest('[data-close-browser]');
        if (close) {
          e.preventDefault();
          var browser2 = close.closest('.file-browser-list');
          if (browser2) browser2.remove();
          return;
        }
        // Confirm-delete: show confirmation before allowing submit/click
        var del = e.target.closest('[data-confirm-delete]');
        if (del) {
          if (!confirm(del.getAttribute('data-confirm-delete') || '')) {
            e.preventDefault();
          }
        }
      });
    })();
  </script>
</body>
</html>
