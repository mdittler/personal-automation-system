<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= it.title || 'Login — PAS' %></title>
  <link rel="stylesheet" href="/gui/public/pico.min.css" />
  <link rel="stylesheet" href="/gui/public/pas.css" />
</head>
<body>
  <main class="container login-container">
    <div class="login-card">
      <div class="login-brand">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--pas-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <h2>PAS Management</h2>
      </div>
      <% if (it.error) { %>
        <div class="alert-banner alert-banner-error"><%= it.error %></div>
      <% } %>
      <% if (it.reason === 'password-required') { %>
        <div class="alert-banner alert-banner-warning">Multiple admin accounts exist — please log in with your Telegram user ID and password.</div>
      <% } %>

      <!-- Primary: Telegram user ID + password -->
      <form method="post" action="/gui/login">
        <% if (it.csrfToken) { %><input type="hidden" name="_csrf" value="<%= it.csrfToken %>" /><% } %>
        <label for="userId">Telegram User ID</label>
        <input type="text" id="userId" name="userId" placeholder="Your Telegram user ID (e.g. 123456789)" required autofocus autocomplete="username" inputmode="numeric" />
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Your password" required autocomplete="current-password" />
        <button type="submit">Login</button>
      </form>

      <!-- Legacy: single-admin token (collapsed) -->
      <details style="margin-top:1.5rem">
        <summary style="cursor:pointer;color:var(--pico-muted-color);font-size:0.875rem">Single-admin install? Use authentication token</summary>
        <form method="post" action="/gui/login" style="margin-top:0.75rem">
          <% if (it.csrfToken) { %><input type="hidden" name="_csrf" value="<%= it.csrfToken %>" /><% } %>
          <label for="legacyToken" style="font-size:0.875rem">Authentication Token</label>
          <input type="password" id="legacyToken" name="legacyToken" placeholder="Enter your token" autocomplete="off" />
          <button type="submit" class="outline secondary" style="width:100%">Login with token</button>
        </form>
      </details>
    </div>
  </main>
  <script>
    (function() {
      var saved = localStorage.getItem('pas-theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    })();
  </script>
</body>
</html>
