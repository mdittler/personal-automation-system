<div class="page-header">
  <h1>User Context & Preferences</h1>
</div>
<p>Per-user knowledge base. The chatbot uses these entries to personalize responses.</p>

<% for (const user of it.users) { %>
  <h2><%= user.name %> <small>(<code><%= user.id %></code>)</small></h2>

  <div hx-get="/gui/context/<%= user.id %>" hx-trigger="load" hx-swap="innerHTML">
    <p aria-busy="true">Loading entries...</p>
  </div>
<% } %>
