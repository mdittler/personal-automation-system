<div class="page-header">
  <h1>Reports</h1>
  <div class="actions">
    <a href="/gui/reports/new" role="button">Create Report</a>
  </div>
</div>

<% if (it.reports.length === 0) { %>
  <p class="empty-state">No reports configured yet. Create one to get started.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Schedule</th>
        <th>Next Run</th>
        <th>Sections</th>
        <th>LLM</th>
        <th>Enabled</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% for (const report of it.reports) { %>
        <tr>
          <td>
            <strong><%= report.name %></strong>
            <% if (report.validationErrors && report.validationErrors.length > 0) { %>
              <span style="color:var(--pico-color-red-500);margin-left:0.4rem" title="<%= report.validationErrors.map(function(e){return e.field+': '+e.message}).join('; ') %>">&#9888; Invalid</span>
            <% } %>
            <% if (report.description) { %>
              <br><small><%= report.description %></small>
            <% } %>
          </td>
          <td><%= report.humanSchedule %></td>
          <td>
            <% if (report.nextRun) { %>
              <%= report.nextRun %>
              <br><small><%= report.nextRunRelative %></small>
            <% } else { %>
              <em><%= report.enabled ? 'Unknown' : 'Disabled' %></em>
            <% } %>
          </td>
          <td><%= report.sectionCount %></td>
          <td><%= report.llmEnabled ? 'Yes' : 'No' %></td>
          <td>
            <span id="toggle-<%= report.id %>">
              <form method="post"
                    action="/gui/reports/<%= report.id %>/toggle"
                    hx-post="/gui/reports/<%= report.id %>/toggle"
                    hx-target="#toggle-<%= report.id %>"
                    hx-swap="innerHTML"
                    style="margin:0">
                <button type="submit" class="toggle-btn outline <%= report.enabled ? 'secondary' : '' %>">
                  <span class="badge <%= report.enabled ? 'badge-ok' : 'badge-err' %>"><%= report.enabled ? 'On' : 'Off' %></span>
                </button>
              </form>
            </span>
          </td>
          <td>
            <a href="/gui/reports/<%= report.id %>/edit" style="margin-right:0.5rem">Edit</a>
            <a href="/gui/reports/<%= report.id %>/history">History</a>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>
